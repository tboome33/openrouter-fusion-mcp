# Required — an OpenRouter INFERENCE key with credit (a provisioning/management key
# returns 401 "User not found"). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — global default reasoning effort for configs that don't set their own.
# One of: xhigh | high | medium | low | minimal | none. Defaults to "high".
#OPENROUTER_FUSION_DEFAULT_REASONING=high

# Optional — named custom configs, ONE ENV VAR PER CONFIG: OPENROUTER_FUSION_<NAME>.
# Value is a JSON object. Built-in "quality" and "budget" need no env var.
# Fields: analysis_models (panel) · judge (orchestrator) · reasoning_effort
# (xhigh|high|medium|low|minimal|none) · temperature (null = model default) · system (optional).
#OPENROUTER_FUSION_CODE={"name":"code","label":"Code","analysis_models":["z-ai/glm-5.2","anthropic/claude-opus-4.8","openai/gpt-5.5","deepseek/deepseek-v4-pro"],"judge":"anthropic/claude-opus-4.8","reasoning_effort":"high","temperature":null}
